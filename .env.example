# Neural Flow Architect — environment template
# Copy to .env and adjust. Never commit real secrets or neural data paths that leave the device.

NFA_ENV=development
NFA_LOG_LEVEL=INFO

# Local-first defaults
NFA_LOCAL_ONLY=true
NFA_ALLOW_CLOUD_LLM=false
NFA_DATA_DIR=./data

# Signal source: simulator | brainflow | neuralink_stub
NFA_ADAPTER=simulator
NFA_SAMPLE_RATE_HZ=250
NFA_CHANNELS=8

# BrainFlow (optional)
# NFA_BRAINFLOW_BOARD_ID=-1
# NFA_BRAINFLOW_SERIAL_PORT=

# Agent
NFA_AGENT_MODE=rules  # rules | llm_local | llm_cloud (cloud requires explicit consent)
NFA_EXPLAIN_ACTIONS=true
NFA_REQUIRE_CONFIRM_FOR_HIGH_IMPACT=true

# Environment orchestration (disabled by default)
NFA_IOT_ENABLED=false
# NFA_HOME_ASSISTANT_URL=
# NFA_HOME_ASSISTANT_TOKEN=

# API
NFA_API_HOST=127.0.0.1
NFA_API_PORT=8741
